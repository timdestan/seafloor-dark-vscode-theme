    "editorBracketHighlight.foreground5": "#5e8878",
    "editorBracketHighlight.foreground6": "#4a7a8a",
    "editorBracketHighlight.unexpectedBracket.foreground": "#f38ba880",
    "editorOverviewRuler.border": "#1e1e2e",
